# ── App (Vercel / local dev) ─────────────────────────────────────────
# Supabase Postgres connection string (use the pooled connection for serverless)
DATABASE_URL=

# Bearer token protecting the /api/sync/* routes (generate a long random string)
SYNC_API_TOKEN=

# ── Sync script (per trading machine, in sync/.env) ──────────────────
# Identifies this machine on every trade row, e.g. laptop | desktop
MACHINE_NAME=

# Deployed app URL the sync script pushes to, e.g. https://your-app.vercel.app
API_BASE_URL=

# Same token as above — the sync script authenticates with it
# SYNC_API_TOKEN=
